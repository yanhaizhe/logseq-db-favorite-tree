{
  "name": "logseq-db-favorite-tree",
  "version": "1.0.0",
  "description": "A Logseq plugin that renders favorite pages as roots in a property-driven tree for DB graphs.",
  "type": "module",
  "main": "dist/index.html",
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build"
  },
  "keywords": [
    "logseq",
    "plugin",
    "favorite",
    "tree",
    "db-graph"
  ],
  "author": "yanhaizhe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yanhaizhe/logseq-db-favorite-tree.git"
  },
  "homepage": "https://github.com/yanhaizhe/logseq-db-favorite-tree",
  "bugs": {
    "url": "https://github.com/yanhaizhe/logseq-db-favorite-tree/issues"
  },
  "dependencies": {
    "@logseq/libs": "^0.0.17"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  },
  "logseq": {
    "id": "logseq-db-favorite-tree",
    "title": "DB Favorite Tree",
    "main": "dist/index.html",
    "icon": "./icon.svg",
    "unsupportedGraphType": "file"
  }
}
